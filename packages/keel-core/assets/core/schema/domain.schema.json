{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keel.dev/schema/2.0/domain.schema.json",
  "title": "Keel Domain Layer",
  "description": "Modelado del dominio: value types, entidades, relaciones e invariantes.",
  "type": "object",
  "required": ["entities"],
  "additionalProperties": false,
  "properties": {
    "types": {
      "type": "object",
      "description": "Value types reutilizables: escalares con restricciones, enums nominales o value objects compuestos.",
      "propertyNames": { "pattern": "^[A-Z][A-Za-z0-9]*$" },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "description": "Value type escalar sobre un tipo base con restricciones.",
            "required": ["base"],
            "additionalProperties": false,
            "properties": {
              "base": { "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/baseType" },
              "description": { "type": "string" },
              "constraints": { "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/constraints" }
            }
          },
          {
            "type": "object",
            "description": "Enum nominal reutilizable entre entidades, operaciones y eventos.",
            "required": ["values"],
            "additionalProperties": false,
            "properties": {
              "values": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "description": { "type": "string" }
            }
          },
          {
            "type": "object",
            "description": "Value object compuesto: varios campos sin identidad propia.",
            "required": ["fields"],
            "additionalProperties": false,
            "properties": {
              "fields": { "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/fieldMap" },
              "description": { "type": "string" }
            }
          }
        ]
      }
    },
    "aggregates": {
      "type": "object",
      "description": "Fronteras de consistencia del dominio: cada agregado declara su entidad raíz y las entidades internas que cambian con ella en la misma transacción.",
      "propertyNames": { "pattern": "^[A-Z][A-Za-z0-9]*$" },
      "additionalProperties": {
        "type": "object",
        "required": ["root"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "root": {
            "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/typeName",
            "description": "Entidad raíz: único punto de entrada del agregado."
          },
          "entities": {
            "type": "array",
            "description": "Entidades internas del agregado (la raíz es miembro implícito, no se repite aquí).",
            "items": { "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/typeName" },
            "uniqueItems": true
          }
        }
      }
    },
    "entities": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Z][A-Za-z0-9]*$" },
      "additionalProperties": {
        "type": "object",
        "required": ["fields"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "fields": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "pattern": "^[a-z][A-Za-z0-9]*$" },
            "additionalProperties": { "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/field" }
          },
          "relations": {
            "type": "object",
            "propertyNames": { "pattern": "^[a-z][A-Za-z0-9]*$" },
            "additionalProperties": {
              "type": "object",
              "required": ["entity", "cardinality"],
              "additionalProperties": false,
              "properties": {
                "entity": { "$ref": "https://keel.dev/schema/2.0/common.schema.json#/$defs/typeName" },
                "cardinality": {
                  "type": "string",
                  "enum": ["one-to-one", "one-to-many", "many-to-one", "many-to-many"]
                },
                "required": { "type": "boolean", "default": false },
                "description": { "type": "string" }
              }
            }
          },
          "lifecycle": {
            "type": "object",
            "description": "Máquina de estados de la entidad sobre un campo enum: solo las transiciones listadas son válidas.",
            "required": ["field", "transitions"],
            "additionalProperties": false,
            "properties": {
              "field": {
                "type": "string",
                "pattern": "^[a-z][A-Za-z0-9]*$",
                "description": "Campo enum de la entidad que representa el estado."
              },
              "transitions": {
                "type": "object",
                "minProperties": 1,
                "description": "Estado origen → estados destino permitidos. Un array vacío marca un estado terminal.",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "invariants": {
            "type": "array",
            "description": "Reglas que siempre deben cumplirse, en lenguaje declarativo legible por humanos y agentes.",
            "items": { "type": "string", "minLength": 5 }
          }
        }
      }
    }
  }
}
